{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki",       "name": "Loki",       "version": "1.0.0" }
  ],
  "title": "re-caring Observability",
  "uid": "recaring-obs-v1",
  "editable": true,
  "refresh": "30s",
  "schemaVersion": 42,
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "tags": ["re-caring", "spring-boot"],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "datasource", "uid": "grafana" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [

    { "type": "row", "title": "📊 Overview", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "collapsed": false },

    {
      "id": 1, "type": "stat", "title": "Total Requests (24h)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }] } }, "overrides": [] },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(http_server_requests_seconds_count{job=\"recaring\", uri!=\"/actuator/prometheus\"})",
        "instant": true, "refId": "A"
      }]
    },

    {
      "id": 2, "type": "stat", "title": "Request Per Second (현재)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }] } }, "overrides": [] },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(rate(http_server_requests_seconds_count{job=\"recaring\", uri!=\"/actuator/prometheus\"}[1m]))",
        "instant": true, "refId": "A"
      }]
    },

    {
      "id": 3, "type": "stat", "title": "Total 5xx Errors (24h)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] }
        }, "overrides": []
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(http_server_requests_seconds_count{job=\"recaring\", status=~\"5..\"})",
        "instant": true, "refId": "A"
      }]
    },

    {
      "id": 4, "type": "gauge", "title": "JVM Heap 사용률",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.85 }] }
        }, "overrides": []
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(jvm_memory_used_bytes{job=\"recaring\", area=\"heap\"}) / sum(jvm_memory_max_bytes{job=\"recaring\", area=\"heap\"})",
        "instant": true, "refId": "A"
      }]
    },

    { "type": "row", "title": "🌐 HTTP 요청 분석", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 }, "id": 101, "collapsed": false },

    {
      "id": 5, "type": "timeseries", "title": "Request Per Second (URI별)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "auto" } }, "overrides": [] },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by(uri, method) (rate(http_server_requests_seconds_count{job=\"recaring\", uri!=\"/actuator/prometheus\"}[1m]))",
        "legendFormat": "[{{method}}] {{uri}}", "refId": "A"
      }]
    },

    {
      "id": 6, "type": "timeseries", "title": "P95 응답시간",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0, "showPoints": "auto" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 1 }] }
        }, "overrides": []
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "histogram_quantile(0.95, sum by(uri, le) (rate(http_server_requests_seconds_bucket{job=\"recaring\", uri!=\"/actuator/prometheus\"}[1m])))",
        "legendFormat": "{{uri}}", "refId": "A"
      }]
    },

    {
      "id": 7, "type": "timeseries", "title": "P99 응답시간",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0, "showPoints": "auto" }
        }, "overrides": []
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "histogram_quantile(0.99, sum by(uri, le) (rate(http_server_requests_seconds_bucket{job=\"recaring\", uri!=\"/actuator/prometheus\"}[1m])))",
        "legendFormat": "{{uri}}", "refId": "A"
      }]
    },

    {
      "id": 8, "type": "timeseries", "title": "5xx 에러율 (%)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single" } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "custom": { "drawStyle": "line", "lineWidth": 1, "thresholdsStyle": { "mode": "area" } },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 0.01 }] }
        }, "overrides": []
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by(uri) (rate(http_server_requests_seconds_count{job=\"recaring\", status=~\"5..\", uri!=\"/actuator/prometheus\"}[1m])) / sum by(uri) (rate(http_server_requests_seconds_count{job=\"recaring\", uri!=\"/actuator/prometheus\"}[1m]))",
        "legendFormat": "{{uri}}", "refId": "A"
      }]
    },

    {
      "id": 9, "type": "bargauge", "title": "URI별 평균 응답시간",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "options": { "displayMode": "lcd", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "showUnfilled": true },
      "fieldConfig": {
        "defaults": {
          "unit": "s", "color": { "mode": "continuous-GrYlRd" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.3 }, { "color": "red", "value": 1 }] }
        }, "overrides": []
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by(uri, method) (http_server_requests_seconds_sum{job=\"recaring\", uri!=\"/actuator/prometheus\"}) / sum by(uri, method) (http_server_requests_seconds_count{job=\"recaring\", uri!=\"/actuator/prometheus\"})",
        "legendFormat": "[{{method}}] {{uri}}", "instant": true, "refId": "A"
      }]
    },

    { "type": "row", "title": "⚙️ JVM / 시스템 리소스", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }, "id": 102, "collapsed": false },

    {
      "id": 10, "type": "timeseries", "title": "CPU 사용률",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single" } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.6 }, { "color": "red", "value": 0.8 }] }
        }, "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "process_cpu_usage{job=\"recaring\"}",
          "legendFormat": "Process CPU", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "system_cpu_usage{job=\"recaring\"}",
          "legendFormat": "System CPU", "refId": "B"
        }
      ]
    },

    {
      "id": 11, "type": "timeseries", "title": "JVM Heap 메모리",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single" } },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20 }
        }, "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(jvm_memory_used_bytes{job=\"recaring\", area=\"heap\"})",
          "legendFormat": "Heap Used", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(jvm_memory_max_bytes{job=\"recaring\", area=\"heap\"})",
          "legendFormat": "Heap Max", "refId": "B"
        }
      ]
    },

    {
      "id": 12, "type": "timeseries", "title": "GC Pause 시간",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80 }
        }, "overrides": []
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "rate(jvm_gc_pause_seconds_sum{job=\"recaring\"}[1m])",
        "legendFormat": "{{action}} {{cause}}", "refId": "A"
      }]
    },

    { "type": "row", "title": "📋 로그", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }, "id": 103, "collapsed": false },

    {
      "id": 13, "type": "timeseries", "title": "로그 레벨 발생 빈도",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 33 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single" } },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal", "group": "A" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WARN"  }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "INFO"  }, "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] }
        ]
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "expr": "sum by(level) (rate({service_name=\"recaring\", level=~\"INFO|WARN|ERROR\"}[1m]))",
        "legendFormat": "{{level}}", "queryType": "range", "refId": "A"
      }]
    },

    {
      "id": 14, "type": "logs", "title": "전체 로그 (INFO / WARN / ERROR)",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 33 },
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "fontSize": "small", "showTime": true, "sortOrder": "Descending", "syntaxHighlighting": true, "wrapLogMessage": true },
      "targets": [{
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "expr": "{service_name=\"recaring\", level=~\"INFO|WARN|ERROR\"}",
        "queryType": "range", "refId": "A"
      }]
    },

    {
      "id": 15, "type": "logs", "title": "ERROR 로그",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "fontSize": "small", "showTime": true, "sortOrder": "Descending", "syntaxHighlighting": true, "wrapLogMessage": false },
      "targets": [{
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "expr": "{service_name=\"recaring\", level=\"ERROR\"}",
        "queryType": "range", "refId": "A"
      }]
    },

    {
      "id": 16, "type": "logs", "title": "WARN 로그",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "fontSize": "small", "showTime": true, "sortOrder": "Descending", "syntaxHighlighting": true, "wrapLogMessage": false },
      "targets": [{
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "expr": "{service_name=\"recaring\", level=\"WARN\"}",
        "queryType": "range", "refId": "A"
      }]
    }

  ]
}
